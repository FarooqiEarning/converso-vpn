# ═══════════════════════════════════════════════
# Converso VPN - Environment Configuration
# Copy to .env and fill all values before deploy
# NEVER commit .env to version control
# ═══════════════════════════════════════════════

# ═══════════════════════════════════════════════
# SHARED
# ═══════════════════════════════════════════════
NODE_ENV=production

# ─── APP ───────────────────────────────────────
APP_PORT=3000
APP_NAME=converso-api
APP_VERSION=1.0.0
FRONTEND_URL=https://app.vpn.conversoempire.world
ADMIN_URL=https://admin.vpn.conversoempire.world
CORS_ORIGINS=https://app.vpn.conversoempire.world,https://admin.vpn.conversoempire.world

# ─── DATABASE ──────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=converso_user
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_NAME=converso_vpn
DATABASE_SSL=false
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=30

# ─── REDIS ─────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_TTL_SECONDS=86400

# ─── JWT ───────────────────────────────────────
JWT_ACCESS_SECRET=GENERATE_64_CHAR_RANDOM_SECRET_ACCESS
JWT_REFRESH_SECRET=GENERATE_64_CHAR_RANDOM_SECRET_REFRESH
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── NEXTAUTH (Web) ───────────────────────────
NEXTAUTH_URL=https://app.vpn.conversoempire.world
NEXTAUTH_SECRET=GENERATE_64_CHAR_RANDOM_SECRET_NEXTAUTH

# ─── GOOGLE OAUTH ──────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.vpn.conversoempire.world/v1/auth/google/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ─── STRIPE ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXX

# ─── EMAIL (Resend) ────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
RESEND_EMAIL_FROM=noreply@vpn.conversoempire.world
RESEND_EMAIL_FROM_NAME=Converso VPN

# ─── NODE AGENT SECRET ─────────────────────────
NODE_AGENT_SECRET=GENERATE_STRONG_SECRET_FOR_AGENTS
NODE_HEARTBEAT_INTERVAL_SECONDS=30

# ─── WIREGUARD ─────────────────────────────────
WG_DNS_PRIMARY=1.1.1.1
WG_DNS_SECONDARY=1.0.0.1
WG_KEEPALIVE_SECONDS=25

# ─── ENCRYPTION ───────────────────────────────
ENCRYPTION_KEY=GENERATE_32_BYTE_AES_KEY_BASE64

# ─── RATE LIMITING ─────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── MONITORING ───────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=STRONG_GRAFANA_PASSWORD

# ─── LOGGING ───────────────────────────────────
LOG_LEVEL=info

# ─── API URL (Web) ────────────────────────────
NEXT_PUBLIC_API_URL=https://api.vpn.conversoempire.world/v1